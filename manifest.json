{
  "manifest_version": 3,
  "name": "PopUpVocab",
  "version": "1.0",
  "description": "Shows a random English word after 15 min",
  "permissions": [
    "storage",
    "alarms"
  ],
  "host_permissions": [
    "https://random-word-api.herokuapp.com/*",
    "https://api.dictionaryapi.dev/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"  
  },
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["style.css"]
    }
  ]
}
