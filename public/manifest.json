{
  "manifest_version": 3,
  "name": "PopUpVocab",
  "version": "1.0",
  "description": "Shows a random English word after 15 min",
  "permissions": [
    "scripting",
    "storage",
    "alarms"
  ],
  "host_permissions": [
    "<all_urls>",
    "https://random-word-api.herokuapp.com/*",
    "https://api.dictionaryapi.dev/*"
  ],
  "web_accessible_resources": [
    {
      "resources": [ "images/*.png" ],
      "matches": [ "<all_urls>" ]
    }
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"  
  },
  "action": {
    "default_popup": "src/action/popup.html",
    "type": "module"  
    
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ]
}