{
  "manifest_version": 3,
  "name": "PopUpVocab",
  "version": "1.0",
  "description": "Shows a random English word after a defined interval",
  "permissions": [
    "scripting",
    "storage",
    "alarms"
  ],
  "host_permissions": [
    "<all_urls>",
    "https://random-word-api.herokuapp.com/*",
    "https://api.dictionaryapi.dev/*"
  ],
  "web_accessible_resources": [
    {
      "resources": ["images/*", "sounds/*"],
      "matches": ["<all_urls>"]
    }
  ],
  "background": {
    "service_worker": "background/background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "action/action.html",
    "default_icon": {
      "16": "images/coala_icon.png",
      "48": "images/coala_icon.png",
      "128": "images/coala_icon.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content.js"],
      "css": ["content/content.css"],
      "type": "module"
    }
  ]
}
